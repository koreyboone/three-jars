# Supabase — get these from your Supabase project dashboard → Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your-publishable-key

# Supabase secret key (server-side only, never expose to client)
SUPABASE_SECRET_DEFAULT_KEY=sb_secret_your-secret-key

# Secret used to sign kid session JWTs (generate with: openssl rand -base64 32)
KID_SESSION_SECRET=replace-with-a-random-32-byte-base64-string
